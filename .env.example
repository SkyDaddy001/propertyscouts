# Gemini AI API
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=propertyscouts

# n8n Webhook (for price updates)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/prices-update
N8N_AUTH_TOKEN=your_n8n_auth_token

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
HOTJAR_ID=

# Environment
NODE_ENV=production
SITE_URL=https://propertyscouts.in
